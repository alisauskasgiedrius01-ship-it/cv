# Copy this file to .env and fill in your own values.
# NOTE: In a Vite app, every VITE_* variable is compiled into the public
# JS bundle and is visible to anyone in the browser. Do not put true
# secrets here. Protect EmailJS via "Allowed Origins" in its dashboard.

# EmailJS (these are public by design)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# SHA-256 hex hash of the admin password (not the password itself).
# Generate with:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
VITE_ADMIN_PASSWORD_HASH=
